---
import type { SvgIconProps } from '@libs/icon'

type Props = SvgIconProps

const { class: className, height, width } = Astro.props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  fill="currentColor"
  viewBox="0 0 16 16"
  class={className}
  height={height}
  width={width}
  aria-hidden="true"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="round"
>
  <path d="M1 3.5h14M1 8h14M1 12.5h14" />
</svg>
