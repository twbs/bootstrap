---
import type { Layout } from '@libs/layout'
import DocsScripts from './DocsScripts.astro'

interface Props {
  layout: Layout
}

const { layout } = Astro.props
---

<script>
  import application from '../assets/application.js'
  import search from '../assets/search.js'

  application()
  search()
</script>

{layout === 'docs' && <DocsScripts />}
