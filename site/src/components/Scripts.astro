---
import type { Layout } from '@libs/layout'
import applicationScriptUrl from '@assets/application.js?url'
import searchScriptUrl from '@assets/search.js?url'
import DocsScripts from './DocsScripts.astro'

interface Props {
  layout: Layout
}

const { layout } = Astro.props
---

<script src={applicationScriptUrl}></script>
<script src={searchScriptUrl}></script>

{layout === 'docs' && <DocsScripts />}
