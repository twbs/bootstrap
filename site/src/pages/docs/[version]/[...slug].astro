---
import type { InferGetStaticPropsType } from 'astro'
import { render } from 'astro:content'
import DocsLayout from '@layouts/DocsLayout.astro'
import * as shortcodes from '@components/shortcodes'
import { getConfig } from '@libs/config'
import { docsPages, getDocsPageSlug } from '@libs/content'

export async function getStaticPaths() {
  return docsPages.map((docsPage) => {
    return {
      params: { slug: getDocsPageSlug(docsPage.id), version: getConfig().docs_version },
      props: docsPage
    }
  })
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { id, data } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(Astro.props)
---

<DocsLayout frontmatter={remarkPluginFrontmatter as typeof data} headings={headings} id={id}>
  <Content components={{ ...shortcodes, pre: shortcodes.Code }} />
</DocsLayout>
